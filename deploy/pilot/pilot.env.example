# Core
TARS_SERVER_LISTEN=:8081
TARS_OPS_API_ENABLED=true
TARS_OPS_API_TOKEN=REPLACE_WITH_OPS_API_TOKEN
TARS_WEB_DIST_DIR=/var/lib/tars/web-dist
TARS_POSTGRES_DSN=postgres://tars:tars@127.0.0.1:5432/tars?sslmode=disable
TARS_VECTOR_SQLITE_PATH=/var/lib/tars/tars-vec.db
TARS_LOG_LEVEL=INFO

# Telegram
TARS_TELEGRAM_BOT_TOKEN=replace-with-bot-token
TARS_TELEGRAM_BASE_URL=https://api.telegram.org
TARS_TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret
TARS_TELEGRAM_POLLING_ENABLED=true
TARS_TELEGRAM_POLL_TIMEOUT=30s
TARS_TELEGRAM_POLL_INTERVAL=1s

# VM / vmalert
TARS_VM_BASE_URL=http://127.0.0.1:8428/select/0/prometheus
TARS_VM_TIMEOUT=15s
TARS_VMALERT_WEBHOOK_SECRET=replace-with-vmalert-secret

# Model / Providers
TARS_MODEL_TIMEOUT=90s
TARS_PROVIDERS_CONFIG_PATH=/etc/tars/providers.yaml
TARS_REASONING_PROMPTS_CONFIG_PATH=/etc/tars/reasoning-prompts.yaml
TARS_DESENSITIZATION_CONFIG_PATH=/etc/tars/desensitization.yaml

# SSH / execution
TARS_SSH_USER=root
TARS_SSH_PRIVATE_KEY_PATH=/etc/tars/id_rsa
TARS_SSH_ALLOWED_HOSTS=192.168.3.100
TARS_SSH_CONNECT_TIMEOUT=10s
TARS_SSH_COMMAND_TIMEOUT=5m
TARS_EXECUTION_OUTPUT_SPOOL_DIR=/var/lib/tars/execution-output
TARS_EXECUTION_OUTPUT_RETENTION=168h

# Policy / routing
TARS_APPROVALS_CONFIG_PATH=/etc/tars/approvals.yaml
TARS_AUTHORIZATION_CONFIG_PATH=/etc/tars/authorization.yaml

# Rollout
TARS_ROLLOUT_MODE=knowledge_on
