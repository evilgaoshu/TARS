# Template-safe shared test defaults.
# Fill in local secrets and remote access values before any real deployment.

# Core
TARS_SERVER_LISTEN=0.0.0.0:8081
TARS_SERVER_PUBLIC_BASE_URL=http://192.168.3.100:8081
TARS_OPS_API_ENABLED=true
TARS_OPS_API_TOKEN=REPLACE_WITH_OPS_API_TOKEN
TARS_WEB_DIST_DIR=REPLACE_WITH_REMOTE_WEB_DIST
TARS_POSTGRES_DSN=postgres://tars:tars@127.0.0.1:5432/tars?sslmode=disable
TARS_RUNTIME_CONFIG_REQUIRE_POSTGRES=true
TARS_SECRET_CUSTODY_KEY=REPLACE_WITH_32_BYTE_OR_BASE64_32_BYTE_SECRET_CUSTODY_KEY
TARS_SECRET_CUSTODY_KEY_ID=local-shared
TARS_VECTOR_SQLITE_PATH=REPLACE_WITH_REMOTE_DATA_DIR/tars-vec.db
TARS_OBSERVABILITY_DATA_DIR=REPLACE_WITH_REMOTE_DATA_DIR/observability
TARS_LOG_LEVEL=INFO
TARS_GC_ENABLED=true
TARS_GC_INTERVAL=1h

# Telegram
TARS_TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TARS_TELEGRAM_BASE_URL=https://api.telegram.org
TARS_TELEGRAM_POLLING_ENABLED=true
TARS_TELEGRAM_POLL_TIMEOUT=30s
TARS_TELEGRAM_POLL_INTERVAL=1s

# VM / vmalert
TARS_VM_BASE_URL=http://127.0.0.1:8428/select/0/prometheus
TARS_VM_TIMEOUT=15s
TARS_VMALERT_WEBHOOK_SECRET=REPLACE_WITH_VMALERT_WEBHOOK_SECRET

# Reasoning / providers / secrets
TARS_MODEL_TIMEOUT=90s
TARS_PROVIDERS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/providers.shared.yaml
TARS_CONNECTORS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/connectors.shared.yaml
TARS_SKILLS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/skills.shared.yaml
TARS_AUTOMATIONS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/automations.shared.yaml
TARS_EXTENSIONS_STATE_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/extensions.state.yaml
TARS_REASONING_PROMPTS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/reasoning-prompts.shared.yaml
TARS_DESENSITIZATION_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/desensitization.shared.yaml
TARS_SECRETS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/secrets.shared.yaml
TARS_CONNECTORS_SECRETS_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/secrets.shared.yaml
TARS_REASONING_LOCAL_COMMAND_FALLBACK_ENABLED=false

# SSH / execution
TARS_SSH_USER=REPLACE_WITH_SSH_USER
TARS_SSH_PRIVATE_KEY_PATH=REPLACE_WITH_SSH_PRIVATE_KEY_PATH
TARS_SSH_ALLOWED_HOSTS=REPLACE_WITH_SSH_ALLOWED_HOSTS
TARS_SSH_CONNECT_TIMEOUT=10s
TARS_SSH_COMMAND_TIMEOUT=5m
TARS_SSH_DISABLE_HOST_KEY_CHECKING=false
TARS_EXECUTION_OUTPUT_SPOOL_DIR=REPLACE_WITH_REMOTE_EXECUTION_OUTPUT_DIR
TARS_EXECUTION_OUTPUT_MAX_PERSISTED_BYTES=262144
TARS_EXECUTION_OUTPUT_CHUNK_BYTES=16384
TARS_EXECUTION_OUTPUT_RETENTION=168h

# Policy / routing
TARS_APPROVAL_TIMEOUT=15m
TARS_APPROVALS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/approvals.shared.yaml
TARS_AUTHORIZATION_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/authorization.shared.yaml
TARS_ACCESS_CONFIG_PATH=REPLACE_WITH_REMOTE_SHARED_DIR/access.shared.yaml

# Rollout
TARS_ROLLOUT_MODE=knowledge_on
