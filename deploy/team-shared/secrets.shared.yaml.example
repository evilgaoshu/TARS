secrets:
  entries:
    - ref: connector/jumpserver-main/access_key
      value: REPLACE_WITH_JUMPSERVER_ACCESS_KEY
      source: team_shared_repo
    - ref: connector/jumpserver-main/secret_key
      value: REPLACE_WITH_JUMPSERVER_SECRET_KEY
      source: team_shared_repo
    - ref: provider/dashscope-kimi/api_key
      value: REPLACE_WITH_DASHSCOPE_API_KEY
      source: team_shared_repo
    - ref: provider/gemini-backup/api_key
      value: REPLACE_WITH_GEMINI_API_KEY
      source: team_shared_repo
